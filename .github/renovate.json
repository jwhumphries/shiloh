{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>jwhumphries/renovate-config"
  ],
  "baseBranchPatterns": [
    "dev"
  ],
  "minimumReleaseAge": "1 day",
  "platformAutomerge": true,
  "npm": {
    "managerFilePatterns": [
      "/(^|/)package\\.hugo\\.json$/"
    ]
  },
  "packageRules": [
    {
      "description": "Automerge minor changes",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    },
    {
      "description": "Ignore package.json (generated from package.hugo.json)",
      "matchFileNames": [
        "package.json"
      ],
      "enabled": false
    }
  ]
}
